# BookmarkFeeder — LOCAL docker compose run
#
# Runs the production artifact on your own machine: same images, same compose, same wiring as the
# NAS. Use it to prove a release actually starts before shipping it.
#
#   cp docker/.env.local.template docker/.env
#   docker compose -f docker/docker-compose.yaml up -d
#   open http://localhost:8080
#
# For day-to-day development use the AppHost instead (`dotnet run --project BookmarkFeeder.AppHost`)
# — it gives hot reload and the dev dashboard. This is for testing what actually ships.
#
# These are throwaway local values, not secrets. Never reuse them on the NAS.

# Shared X-API-Key. The dev default, already in the repo and the docs.
API_KEY=dev-local-bookmarkfeeder-key

# Local Postgres password. Only ever reachable from inside the compose network.
POSTGRES_PASSWORD=local-dev-password

# Published port for the gateway — the ONLY way in. http://localhost:8080
# Both sides of the mapping and the gateway's own HTTP_PORTS come from this one value.
GATEWAY_PORT=8080

# Internal container port for the API. Not published; reached through the gateway.
WEBAPI_PORT=8080

# Where Postgres writes its cluster. Defaults to ./data/postgres next to the compose file
# (docker/data/postgres — gitignored). Delete that directory to start from an empty database.
#POSTGRES_DATA_PATH=./data/postgres

# Images. Either the tags a release pushed, or whatever ./scripts/docker-build.sh built locally —
# docker prefers a local image with the same name, so a local build needs no change here.
WEBAPI_IMAGE=docker.io/mgpeter/bookmarkfeeder-webapi:0.1.0
GATEWAY_IMAGE=docker.io/mgpeter/bookmarkfeeder-gateway:0.1.0
WEB_IMAGE=docker.io/mgpeter/bookmarkfeeder-web:0.1.0
